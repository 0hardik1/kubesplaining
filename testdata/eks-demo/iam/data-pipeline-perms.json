{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DemoReadFlag",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::__BUCKET__",
        "arn:aws:s3:::__BUCKET__/*"
      ]
    },
    {
      "Sid": "DemoIdentityCheck",
      "Effect": "Allow",
      "Action": [
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DemoDescribeOwnCluster",
      "Effect": "Allow",
      "Action": [
        "eks:DescribeCluster"
      ],
      "Resource": "*"
    }
  ]
}
